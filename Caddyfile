{
    admin off
    auto_https off
}

:8080 {
    log {
        output stdout
        format console
    }

    root * /srv/public
    file_server {
        index index.html
    }

    handle_errors {
        @404 expression {http.error.status_code} == 404
        respond @404 "not found" 404
    }
}
